{
  "expo": {
    "name": "CrediPrest",
    "slug": "crediprest-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.crediprest.app",
      "adaptiveIcon": {
        "backgroundColor": "#10383f",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "CrediPrest necesita acceso a tus fotos para adjuntar comprobantes de pago.",
          "cameraPermission": "CrediPrest necesita acceso a la camara para fotografiar comprobantes de pago.",
          "microphonePermission": false
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#157064",
          "defaultChannel": "crediprest-alerts"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e720ac50-7617-44f2-bf3d-381c43bdda09"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e720ac50-7617-44f2-bf3d-381c43bdda09"
    }
  }
}
